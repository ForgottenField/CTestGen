         (Eq 0 (Read w8 22 line))
         (Eq 59 (Read w8 0 line))
         (Eq 59 (Read w8 1 line))
         (Eq 59 (Read w8 2 line))
         (Eq 59 (Read w8 3 line))
         (Eq 59 (Read w8 4 line))
         (Eq 59 (Read w8 5 line))
