array choice[4] : w32 -> w8 = symbolic
array line[64] : w32 -> w8 = symbolic
(query [(Eq 0
             (ReadLSB w32 0 choice))
         (Eq 0 (Read w8 63 line))
         (Eq false
             (Eq 0 N0:(Read w8 4 line)))
         (Eq false
             (Eq 0 N1:(Read w8 5 line)))
         (Eq false
             (Eq 0 N2:(Read w8 6 line)))
         (Eq false
             (Eq 0 N3:(Read w8 7 line)))
         (Eq false
             (Eq 0 N4:(Read w8 8 line)))
         (Eq false
             (Eq 0 N5:(Read w8 14 line)))
         (Eq false
             (Eq 0 N6:(Read w8 15 line)))
         (Eq 0 (Read w8 16 line))
         (Eq false (Eq 59 N0))
         (Eq false (Eq 59 N1))
         (Eq false (Eq 59 N2))
         (Eq false (Eq 59 N3))
         (Eq false (Eq 59 N4))
         (Eq 59 (Read w8 9 line))
         (Eq 116 (Read w8 0 line))
         (Eq 97 (Read w8 1 line))
         (Eq 103 (Read w8 2 line))
         (Eq 61 (Read w8 3 line))
         (Eq 59 (Read w8 10 line))
         (Eq 59 (Read w8 11 line))
         (Eq 59 (Read w8 12 line))
         (Eq 59 (Read w8 13 line))
         (Eq false (Eq 59 N5))
         (Eq false (Eq 59 N6))]
        false)
