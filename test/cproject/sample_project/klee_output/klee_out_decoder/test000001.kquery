array choice[4] : w32 -> w8 = symbolic
array compressed_len[8] : w32 -> w8 = symbolic
array decoded_cap[8] : w32 -> w8 = symbolic
(query [(Ult (ReadLSB w32 0 choice)
              1)
         (Eq false
             (Ult 0
                  (ReadLSB w64 0 decoded_cap)))
         (Eq false
             (Eq 0
                 N0:(ReadLSB w64 0 compressed_len)))
         (Eq 0 (URem w64 N0 2))]
        false)
